# =============================================================================
# CertChain Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (already in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Cardano Wallet (Preprod testnet)
# -----------------------------------------------------------------------------
# How to get:
#   1. Install Lace wallet extension: https://www.lace.io/
#   2. Create new wallet → IMPORTANT: Switch network to "Preprod" in settings
#   3. Settings → Security → Show recovery phrase → Copy 24 words
#   4. Paste below (separated by single spaces)
#
# ⚠️  WARNING: This is a TEST wallet. Never use mnemonic of mainnet wallet here.
WALLET_MNEMONIC="word1 word2 word3 ... word24"

# -----------------------------------------------------------------------------
# Blockfrost API (Cardano blockchain provider)
# -----------------------------------------------------------------------------
# How to get:
#   1. Sign up free at https://blockfrost.io/
#   2. Create new project → Network: "Cardano preprod"
#   3. Copy Project ID
BLOCKFROST_PREPROD_KEY="preprod..."

# -----------------------------------------------------------------------------
# Optional: Mainnet (chỉ dùng khi production)
# -----------------------------------------------------------------------------
# BLOCKFROST_MAINNET_KEY="mainnet..."
